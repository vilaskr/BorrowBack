{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the BorrowBack app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "name", "email"]
    },
    "BorrowEntry": {
      "title": "BorrowEntry",
      "description": "A record of an item lent or borrowed.",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "lenderID": { "type": "string" },
        "borrowerID": { "type": "string" },
        "lenderEmail": { "type": "string" },
        "borrowerEmail": { "type": "string" },
        "lenderName": { "type": "string" },
        "borrowerName": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["REQUESTED", "ACTIVE", "RETURN_REQUESTED", "RETURNED", "CANCELLED"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "returnDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "returnRequestedBy": { "type": "string" },
        "lastReminderSentAt": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" },
        "returnedAmount": { "type": "number" },
        "isMonetary": { "type": "boolean" },
        "entryType": { "type": "string", "enum": ["lent", "borrowed"] },
        "isPendingSync": { "type": "boolean" },
        "sharedTransactionId": { "type": "string" }
      },
      "required": ["itemName", "borrowerEmail", "status", "createdAt"]
    },
    "Friend": {
      "title": "Friend",
      "description": "A saved friend for quick lending.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "addedBy": { "type": "string" },
        "trustScore": { "type": "number" }
      },
      "required": ["name", "email", "addedBy"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/borrowEntries/{entryId}": {
      "schema": "BorrowEntry",
      "description": "Lending records."
    },
    "/friends/{friendId}": {
      "schema": "Friend",
      "description": "User's saved friends."
    }
  }
}
